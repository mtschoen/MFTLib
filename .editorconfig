root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{cs,csproj,xaml,axaml}]
indent_size = 4

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.sln]
indent_style = tab

[*.cs]
# 'private' keyword preference — omit when it's the default accessibility
dotnet_style_require_accessibility_modifiers = omit_if_default

# Naming rules
# Private/internal instance fields: _camelCase
dotnet_naming_rule.private_fields_must_be_underscore_camel.symbols = private_fields
dotnet_naming_rule.private_fields_must_be_underscore_camel.style = underscore_camel_case
dotnet_naming_rule.private_fields_must_be_underscore_camel.severity = warning

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private, internal
dotnet_naming_symbols.private_fields.required_modifiers =

dotnet_naming_style.underscore_camel_case.required_prefix = _
dotnet_naming_style.underscore_camel_case.capitalization = camel_case

# Private/internal static fields: PascalCase (used for Func/Action indirection)
dotnet_naming_rule.private_static_fields_must_be_pascal.symbols = private_static_fields
dotnet_naming_rule.private_static_fields_must_be_pascal.style = pascal_case
dotnet_naming_rule.private_static_fields_must_be_pascal.severity = warning

dotnet_naming_symbols.private_static_fields.applicable_kinds = field
dotnet_naming_symbols.private_static_fields.applicable_accessibilities = private, internal
dotnet_naming_symbols.private_static_fields.required_modifiers = static

dotnet_naming_style.pascal_case.capitalization = pascal_case

# Constants: PascalCase
dotnet_naming_rule.constants_must_be_pascal.symbols = constants
dotnet_naming_rule.constants_must_be_pascal.style = pascal_case
dotnet_naming_rule.constants_must_be_pascal.severity = warning

dotnet_naming_symbols.constants.applicable_kinds = field
dotnet_naming_symbols.constants.required_modifiers = const

# Public/protected members: PascalCase
dotnet_naming_rule.public_members_must_be_pascal.symbols = public_members
dotnet_naming_rule.public_members_must_be_pascal.style = pascal_case
dotnet_naming_rule.public_members_must_be_pascal.severity = warning

dotnet_naming_symbols.public_members.applicable_kinds = property, method, event, delegate, class, struct, interface, enum
dotnet_naming_symbols.public_members.applicable_accessibilities = public, protected

# Parameters and locals: camelCase
dotnet_naming_rule.locals_must_be_camel.symbols = locals
dotnet_naming_rule.locals_must_be_camel.style = camel_case
dotnet_naming_rule.locals_must_be_camel.severity = warning

dotnet_naming_symbols.locals.applicable_kinds = parameter, local

dotnet_naming_style.camel_case.capitalization = camel_case
